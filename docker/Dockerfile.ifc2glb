FROM rust:latest AS builder

RUN rustup default nightly

WORKDIR /app
COPY Cargo.toml rust-toolchain.toml ./
COPY rust/ rust/

RUN cargo build --release --bin ifc-lite-headless

FROM debian:bookworm-slim
COPY --from=builder /app/target/release/ifc-lite-headless /usr/local/bin/ifc-lite-headless
ENTRYPOINT ["ifc-lite-headless"]
